NEXT_PUBLIC_APP_URL=https://www.acme.ai

# MapTiler
MAPTILER_API_KEY=your_maptiler_api_key

# Database (Neon Postgres)
# Get these from Vercel Dashboard → Storage → Neon → Connection String
# Use DATABASE_URL (pooled) for serverless functions - recommended for most uses
DATABASE_URL=postgresql://neondb_owner:password@ep-xxx-pooler.c-4.us-east-1.aws.neon.tech/neondb?sslmode=require

# For uses requiring a connection without pgbouncer (rarely needed)
# DATABASE_URL_UNPOOLED=postgresql://neondb_owner:password@ep-xxx.c-4.us-east-1.aws.neon.tech/neondb?sslmode=require
